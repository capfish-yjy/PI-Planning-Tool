{
  "name": "pi-planning-assistant",
  "version": "0.3.0",
  "description": "Read-only Jira PI planning desktop assistant.",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "generate:icons": "node scripts/generate-icons.mjs",
    "dist:mac:arm64": "npm run generate:icons && npm run build && electron-builder --mac dmg --arm64",
    "dist:mac:x64": "npm run generate:icons && npm run build && electron-builder --mac dmg --x64",
    "dist:win:portable": "npm run generate:icons && npm run build && electron-builder --win portable --x64",
    "dist:all": "npm run dist:mac:arm64 && npm run dist:mac:x64 && npm run dist:win:portable"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@vitejs/plugin-react": "^4.6.0",
    "lucide-react": "^0.468.0",
    "undici": "^7.28.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.pi-planning-assistant.app",
    "productName": "PI Planning Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
